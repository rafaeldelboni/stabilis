const std = @import("std");
const debug = @import("../debug.zig");
const Io = std.Io;

pub fn readFile(io: Io, arena: *std.heap.ArenaAllocator, path: []const u8) ![]u8 {
    const allocator = arena.allocator();
    return try std.Io.Dir.readFileAlloc(std.Io.Dir.cwd(), io, path, allocator, .unlimited);
}

const File = struct {
    path: []const u8,
    contents: []const u8,
};

// pub fn walkDir(io: Io, arena: *std.heap.ArenaAllocator, path: []const u8) ![]File {
pub fn walkDir(io: Io, arena: *std.heap.ArenaAllocator, path: []const u8) !void {
    const allocator = arena.allocator();
    const dir = try std.Io.Dir.openDir(std.Io.Dir.cwd(), io, path, .{ .iterate = true });
    defer dir.close(io);

    var dir_entries = dir.iterate();
    while (try dir_entries.next(io)) |dir_entry| {
        switch (dir_entry.kind) {
            .file => {
                const file_ext = std.Io.Dir.path.extension(dir_entry.name);
                const file_base = std.Io.Dir.path.extension(dir_entry.name);
                std.debug.print("[{s: <5}] - {s}\n", .{ file_ext, file_base });
            },
            .directory => {
                std.Io.Dir.path.join(allocator, .{path, dir_entry.name} );
                var buf: std.ArrayList(u8) = .empty;
                try buf.appendSlice(allocator, path);
                try buf.appendSlice(allocator, dir_entry.name);
                try buf.appendSlice(allocator, "/");
                const new = buf.items;
                std.debug.print("[=DIR=] - {s}\n", .{dir_entry.name});
                try walkDir(io, arena, new);
            },
            else => {},
        }
    }
    // std.debug.print("{s}\n", .{debug.dumpJson(arena.allocator(), dir)});
    std.debug.print("{s}\n", .{"true"});

    // sdt.Io.Dir.op
    // std.Io.Dir.walk(dir: Dir, allocator: Allocator)
}

